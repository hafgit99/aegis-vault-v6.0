{
  "name": "aegisvault",
  "private": true,
  "version": "6.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hafgit99/aegis-vault-v6.0.git"
  },
  "bugs": {
    "url": "https://github.com/hafgit99/aegis-vault-v6.0/issues"
  },
  "homepage": "https://github.com/hafgit99/aegis-vault-v6.0#readme",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:checksums": "node scripts/generate-artifact-checksums.mjs",
    "android:doctor": "node scripts/verify-android-readiness.mjs",
    "android:init": "tauri android init",
    "android:dev": "tauri android dev --open",
    "android:build": "npm run android:build:aab",
    "android:build:apk:arm64": "tauri android build --apk --target aarch64",
    "android:build:apk": "tauri android build --apk --split-per-abi",
    "android:build:aab": "tauri android build --aab",
    "android:checksums": "node scripts/generate-artifact-checksums.mjs src-tauri/gen/android/app/build/outputs/apk",
    "android:stage": "node scripts/stage-android-artifacts.mjs src-tauri/gen/android/app/build/outputs/apk android-artifacts/aegisvault-android",
    "brand:icon:source": "node scripts/render-icon-source.mjs",
    "release:verify-version": "node scripts/verify-release-version.mjs",
    "build": "vite build",
    "build:budget": "node scripts/check-build-budget.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=high",
    "security:scan": "node scripts/security-regression-scan.mjs",
    "security:workflows": "node scripts/verify-workflow-permissions.mjs",
    "security:dependencies": "node scripts/verify-dependency-policy.mjs",
    "security:validation": "node scripts/verify-validation-rules.mjs",
    "security:secure-share": "node scripts/verify-secure-share-format.mjs",
    "security:privacy": "node scripts/verify-privacy-notice.mjs",
    "security:signing": "node scripts/verify-release-signing.mjs",
    "security:branch-protection": "node scripts/verify-branch-protection-policy.mjs",
    "security:desktop-smoke": "node scripts/verify-desktop-smoke-policy.mjs",
    "security:logging": "node scripts/verify-security-logging-policy.mjs",
    "security:errors": "node scripts/verify-error-taxonomy.mjs",
    "security:release-notes": "node scripts/verify-release-notes-template.mjs",
    "security:disclosure": "node scripts/verify-vulnerability-disclosure.mjs",
    "security:evidence": "node scripts/generate-security-evidence.mjs && node scripts/verify-security-evidence-bundle.mjs",
    "security:evidence:generate": "node scripts/generate-security-evidence.mjs",
    "security:evidence:verify": "node scripts/verify-security-evidence-bundle.mjs",
    "security:sbom": "node scripts/generate-sbom.mjs",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:firefox:smoke": "playwright test test/e2e/lock-screen.spec.ts --project=firefox --workers=1",
    "test:e2e:mobile-firefox": "playwright test --project=mobile-firefox",
    "test:e2e:mobile-firefox:smoke": "playwright test test/e2e/lock-screen.spec.ts --project=mobile-firefox --workers=1",
    "test:e2e:release": "npm run test:e2e:chromium && npm run test:e2e:firefox:smoke && npm run test:e2e:mobile-firefox:smoke",
    "test:mutation": "stryker run",
    "test:mutation:secure-share": "stryker run stryker.secure-share.config.json",
    "test:mutation:app": "stryker run stryker.app.config.json",
    "test:mutation:database": "stryker run stryker.database.config.json",
    "test:mutation:hooks": "stryker run stryker.hooks.config.json",
    "test:mutation:settings": "stryker run stryker.settings.config.json",
    "test:mutation:ui": "stryker run stryker.ui.config.json",
    "test:mutation:sqlite": "stryker run stryker.sqlite-opfs.config.json",
    "test:mutation:release": "npm run test:mutation && npm run test:mutation:secure-share && npm run test:mutation:sqlite && npm run test:mutation:hooks && npm run test:mutation:settings && npm run test:mutation:database",
    "test:all": "npm run lint && npm run security:scan && npm run security:workflows && npm run security:dependencies && npm run security:validation && npm run security:secure-share && npm run security:privacy && npm run security:signing && npm run security:branch-protection && npm run security:desktop-smoke && npm run security:logging && npm run security:errors && npm run security:release-notes && npm run security:disclosure && npm run security:sbom && npm run security:evidence && npm run audit:prod && npm run test:coverage && npm run build && npm run build:budget && npm run test:e2e:release"
  },
  "dependencies": {
    "@choochmeque/tauri-plugin-biometry-api": "^0.2.8",
    "hash-wasm": "^4.12.0",
    "i18next": "^26.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "react-qr-code": "^2.0.21",
    "sql.js": "^1.14.1",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@types/zxcvbn": "^4.4.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  }
}
