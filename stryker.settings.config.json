{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutator": {
    "excludedMutations": ["StringLiteral", "ObjectLiteral"]
  },
  "mutate": [
    "src/components/settings/BackupExportModal.tsx",
    "src/components/settings/ImportSettingsPanel.tsx",
    "src/components/settings/MasterPasswordSettingsPanel.tsx",
    "src/components/settings/WipeSettingsPanel.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/vite-env.d.ts"
  ],
  "testFiles": [
    "test/unit/settings-database.test.tsx"
  ],
  "ignorePatterns": [
    "/coverage",
    "/dist",
    "/playwright-report",
    "/reports",
    "/test-results"
  ],
  "ignoreStatic": true,
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "thresholds": {
    "high": 45,
    "low": 35,
    "break": 30
  },
  "dryRunTimeoutMinutes": 90,
  "timeoutMS": 60000,
  "concurrency": 2,
  "cleanTempDir": "always"
}
