{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "off",
  "mutate": [
    "src/lib/SQLiteOPFS.ts"
  ],
  "ignorePatterns": [
    "/coverage",
    "/dist",
    "/playwright-report",
    "/reports",
    "/test-results"
  ],
  "commandRunner": {
    "command": "npm run test:unit -- test/unit/sqlite-opfs.test.ts"
  },
  "thresholds": {
    "high": 70,
    "low": 60,
    "break": 60
  },
  "dryRunTimeoutMinutes": 90,
  "timeoutMS": 60000,
  "concurrency": 4,
  "cleanTempDir": "always"
}
